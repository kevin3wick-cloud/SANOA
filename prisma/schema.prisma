generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  LANDLORD
  MIETER
}

enum OrgRole {
  ORG_ADMIN
  ORG_USER
  ORG_GUEST
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum TicketCategory {
  SANITAER
  HEIZUNG
  ELEKTRO
  FENSTER_TUEREN
  ALLGEMEIN
  SONSTIGES
}

enum DocumentVisibility {
  INTERNAL
  TENANT_VISIBLE
}

enum DocumentKind {
  MIETVERTRAG
  HAUSORDNUNG
  NEBENKOSTEN
  MITTEILUNG
  SONSTIGES
}

enum AppointmentProposalStatus {
  PENDING
  CONFIRMED
  REJECTED
  WITHDRAWN
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String
  company         String?
  role            UserRole  @default(LANDLORD)
  orgRole         OrgRole   @default(ORG_USER)
  orgId           String?
  tenantId        String?   @unique
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  assignedTickets Ticket[]  @relation("TicketAssignee")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Property {
  id        String   @id @default(cuid())
  name      String
  address   String?
  orgId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenants   Tenant[]
  assignees PropertyAssignee[]
}

model PropertyAssignee {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime @default(now())

  @@unique([propertyId, userId])
}

model Tenant {
  id          String    @id @default(cuid())
  name        String
  email       String
  phone       String
  apartment   String
  leaseStart  DateTime?
  leaseEnd    DateTime?
  archivedAt  DateTime?
  magicToken  String?   @unique
  orgId       String?
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  pendingName           String?
  pendingNameReason     String?
  pendingNameRequestedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tickets           Ticket[]
  documents         Document[]
  pushSubscriptions PushSubscription[]
  user              User?
}

model Ticket {
  id                     String                     @id @default(cuid())
  title                  String
  description            String
  location               String
  imageUrl               String?
  status                 TicketStatus               @default(OPEN)
  category               TicketCategory
  isUrgent               Boolean                    @default(false)
  aiSummary              String?
  tenantId               String
  tenant                 Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedToId           String?
  assignedTo             User?                      @relation("TicketAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  tenantLastSeenChatAt           DateTime?
  landlordLastSeenChatAt         DateTime?
  tenantLastSeenAppointmentsAt   DateTime?
  landlordLastSeenAppointmentsAt DateTime?
  notes                    TicketNote[]
  appointmentProposals     TicketAppointmentProposal[]
}

model TicketAppointmentProposal {
  id          String                    @id @default(cuid())
  ticketId    String
  ticket      Ticket                    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  message     String
  startAt     DateTime?
  endAt       DateTime?
  status      AppointmentProposalStatus @default(PENDING)
  createdAt   DateTime                  @default(now())
  respondedAt DateTime?

  @@index([ticketId])
}

model TicketNote {
  id               String   @id @default(cuid())
  ticketId         String
  ticket           Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  text             String
  isInternal       Boolean  @default(true)
  isTenantAuthor   Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Contractor {
  id            String   @id @default(cuid())
  name          String
  contactPerson String?  // Ansprechperson; falls leer → Firmenname wird verwendet
  email         String
  phone         String?
  trade         String?  // e.g. Sanitär, Elektro, Maler
  orgId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Document {
  id                 String             @id @default(cuid())
  name               String
  originalFilename   String             @default("")
  fileUrl            String
  visibility         DocumentVisibility @default(INTERNAL)
  kind               DocumentKind       @default(SONSTIGES)
  orgId              String?
  tenantId           String?
  tenant             Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  archivedAt         DateTime?
  createdAt          DateTime           @default(now())
  questions          DocumentQuestion[]
}

model OrgSettings {
  id           String   @id @default(cuid())
  orgId        String   @unique
  senderName   String?  // z.B. "Hausverwaltung Muster AG"
  replyToEmail String?  // z.B. "info@hausverwaltung-muster.ch"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DocumentQuestion {
  id          String    @id @default(cuid())
  documentId  String
  document    Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tenantId    String
  orgId       String?
  question    String
  answer      String?
  answeredAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([documentId])
  @@index([orgId])
}
